	<!-- Slash trail — brief burst of slash motes on melee hit target.
	     Played by HediffComp_PlayEffecter on Heyra_Hediff_Slash (24 ticks duration).
	     Original TrailLeaver spawned 1 random mote every 8 ticks from a pool of 6.
	     4 sub-effecters (one per direction) at ticksBetweenMotes=8 give a rapid slash flurry. -->
	<EffecterDef>
		<defName>Heyra_Effecter_SlashTrail</defName>
		<children>
			<li>
				<subEffecterClass>SubEffecter_DrifterEmoteContinuous</subEffecterClass>
				<moteDef>Heyra_SlashmoteA</moteDef>
				<ticksBetweenMotes>8</ticksBetweenMotes>
			</li>
			<li>
				<subEffecterClass>SubEffecter_DrifterEmoteContinuous</subEffecterClass>
				<moteDef>Heyra_SlashmoteX</moteDef>
				<ticksBetweenMotes>8</ticksBetweenMotes>
			</li>
			<li>
				<subEffecterClass>SubEffecter_DrifterEmoteContinuous</subEffecterClass>
				<moteDef>Heyra_SlashmoteY</moteDef>
				<ticksBetweenMotes>8</ticksBetweenMotes>
			</li>
			<li>
				<subEffecterClass>SubEffecter_DrifterEmoteContinuous</subEffecterClass>
				<moteDef>Heyra_SlashmoteZ</moteDef>
				<ticksBetweenMotes>8</ticksBetweenMotes>
			</li>
		</children>
	</EffecterDef>

	<!-- Activation flash — one-shot effecter for Electricfield ability cast -->
	<EffecterDef>
    <defName>Heyra_Effecter_Sparks</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggeredDelayed</subEffecterClass>
        <fleckDef>PlainFlash</fleckDef>
        <initialDelayTicks>0</initialDelayTicks>
        <burstCount>1~1</burstCount>
        <scale>7.0~7.0</scale>
        <spawnLocType>OnSource</spawnLocType>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggeredDelayed</subEffecterClass>
        <positionRadius>1.3</positionRadius>
        <initialDelayTicks>8</initialDelayTicks>
        <fleckDef>ElectricalSpark</fleckDef>
        <burstCount>7~9</burstCount>
        <scale>2.5</scale>
        <spawnLocType>OnSource</spawnLocType>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggeredDelayed</subEffecterClass>
        <positionRadius>1.3</positionRadius>
        <initialDelayTicks>16</initialDelayTicks>
        <fleckDef>ElectricalSpark</fleckDef>
        <burstCount>5~7</burstCount>
        <scale>2.5</scale>
        <spawnLocType>OnSource</spawnLocType>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggeredDelayed</subEffecterClass>
        <positionRadius>1.3</positionRadius>
        <initialDelayTicks>24</initialDelayTicks>
        <fleckDef>ElectricalSpark</fleckDef>
        <burstCount>3~7</burstCount>
        <scale>1.5</scale>
        <spawnLocType>OnSource</spawnLocType>
      </li>
    </children>
  </EffecterDef>
</Defs>