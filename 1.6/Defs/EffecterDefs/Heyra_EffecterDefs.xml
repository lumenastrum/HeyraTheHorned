	<!--SHADOW-->

	<EffecterDef>
		<defName>Heyra_Effecter_StaticFieldRing</defName>
		<children>
			<!-- Animated spark circle ring (the AOE indicator) -->
			<li>
				<subEffecterClass>SubEffecter_DrifterEmoteContinuous</subEffecterClass>
