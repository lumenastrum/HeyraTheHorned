				<ticksBetweenMotes>24</ticksBetweenMotes>
			</li>
			<!-- Random small sparks (3 sub-effecters cycle through Spark1/2/3) -->
			<li>
				<subEffecterClass>SubEffecter_DrifterEmoteContinuous</subEffecterClass>
