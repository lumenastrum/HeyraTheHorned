  <ThingDef ParentName="Heyra_ApparelBase">
    <defName>Heyra_Rong_Berserkerarmor</defName>
    <description>A strong competitor for the 'least protective armor' crown. Only the fearless Rong Berserkers are brave enough to dive into the battlefield wearing these.</description>
    <label>Rong berserker armor</label>
    <graphicData>
      <texPath>Apparel/Heyra_Rong/Heyra_RongA</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
	<colorGenerator Class="ColorGenerator_Options">
      <options>
	    <li>
          <weight>30</weight>
          <only>(1,1,1)</only>
        </li>
        <li>
          <weight>30</weight>
          <only>(0.3,0.3,0.8)</only>
        </li>
		<li>
          <weight>30</weight>
          <only>(0.3,0.8,0.3)</only>
        </li>
		<li>
          <weight>30</weight>
          <only>(0.8,0.3,0.3)</only>
        </li>
      </options>
	 </colorGenerator>
	 <recipeMaker>
	  <researchPrerequisite Inherit="False">Heyra_Researchrong</researchPrerequisite>
    </recipeMaker>
	 <costStuffCount>40</costStuffCount>
    <stuffCategories>
		<li>Fabric</li>
      <li>Leathery</li>
	 </stuffCategories>
    <statBases>
			<MaxHitPoints>140</MaxHitPoints>
			<WorkToMake>4000</WorkToMake>
			<Mass>0.25</Mass>
			<ArmorRating_Sharp>0.29</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.13</ArmorRating_Blunt>
			<ArmorRating_Heat>0.10</ArmorRating_Heat>
			<Insulation_Cold>10.0</Insulation_Cold>
			<Insulation_Heat>10.0</Insulation_Heat>
			<EquipDelay>2</EquipDelay>
	</statBases>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
		<li>Neck</li>
		<li>Shoulders</li>
		<li>Arms</li>
		<li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>Apparel/Heyra_Rong/Heyra_RongA</wornGraphicPath>
      <layers>
		<li>OnSkin</li>
		<li>Middle</li>
      </layers>
      <defaultOutfitTags>
        <li>Worker</li>
      </defaultOutfitTags>
      <tags>
	  <li>Heyra_ApparelTypeRong</li>
      </tags>
    </apparel>
  </ThingDef>
  
