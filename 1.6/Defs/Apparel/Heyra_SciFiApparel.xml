  <ThingDef ParentName="Heyra_SciFiArmorBase">
		<defName>Heyra_Hmaal</defName>
		<label>HMAA-Light</label>
		<description>Born from the marriage of Heyran craftsmanship and glitterworld technology, the High Mobility Assault Armor - Light, shortened to HMAA-L, provides even better protection than recon armor. It features customized neuro-memetic assist systems fitted exclusively to the Heyran body, stabilizing the wearer during shooting and improving melee capability.</description>
		<graphicData>
			<texPath>Apparel/Heyra_SciFi/Heyra_Hmaal</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<WorkToMake>50000</WorkToMake>
			<MaxHitPoints>400</MaxHitPoints>
			<Mass>12</Mass>
			<Flammability>0.2</Flammability>
			<ArmorRating_Sharp>1.1</ArmorRating_Sharp>
			<ArmorRating_Blunt>1.1</ArmorRating_Blunt>
			<ArmorRating_Heat>0.5</ArmorRating_Heat>
			<Insulation_Cold>35</Insulation_Cold>
			<Insulation_Heat>35</Insulation_Heat>
			<EquipDelay>6</EquipDelay>			
		</statBases>
		<equippedStatOffsets>
			<AimingDelayFactor>-0.1</AimingDelayFactor>
			<MoveSpeed>0.8</MoveSpeed>
			<MeleeDodgeChance>0.25</MeleeDodgeChance>
			<ToxicEnvironmentResistance>0.50</ToxicEnvironmentResistance>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.50</VacuumResistance>
		</equippedStatOffsets>
		<costList>
			<ComponentSpacer>5</ComponentSpacer>
			<Plasteel>100</Plasteel>
			<Uranium>25</Uranium>
		</costList>
		<apparel>
			<bodyPartGroups>
				<li>Tail</li>
			</bodyPartGroups>
			<wornGraphicPath>Apparel/Heyra_SciFi/Heyra_Hmaal</wornGraphicPath>
			<tags>
				<li>Heyra_ApparelTypeHmaal</li>
			</tags>
			<defaultOutfitTags>
				<li>Worker</li>
				<li>Soldier</li>
			</defaultOutfitTags>
		</apparel>
		<colorGenerator Class="ColorGenerator_Options">
			<options>
				<li>
					<weight>100</weight>
					<only>(1,1,1)</only>
				</li>
			</options>
		</colorGenerator>
	</ThingDef>
	
