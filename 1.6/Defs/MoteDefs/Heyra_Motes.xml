	<!-- ===============================hediff============ -->

	<HediffDef>
		<defName>Heyra_Hediff_Showspark</defName>
		<label>ShowSpark</label>

		<hediffClass>HediffWithComps</hediffClass>
		<description>attached motes</description>

		<comps>
			<li Class="HediffCompProperties_Disappears">
				<showRemainingTime>True</showRemainingTime>
			</li>
			<li Class="Heyra.HediffCompProperties_PlayEffecter">
				<effecterDef>Heyra_Effecter_StaticFieldRing</effecterDef>
			</li>
			<li Class="Heyra.HediffCompProperties_RemoveIfHediffNotExists">
			  <hediffDef>Heyra_Hediff_Monsterform</hediffDef>
			</li>
			<li Class="Heyra.HediffCompProperties_AddHediffToBodyPart">
				<hediffsToParts>
					<li>
						<hediffDef>Heyra_Hediff_Electricfield</hediffDef>
						<bodyPartTagDef>TalkingSource</bodyPartTagDef>
						<bodyPartLable>
							<li>jaw</li>
						</bodyPartLable>
					</li>
				</hediffsToParts>
			</li>
		</comps>

		<stages>
			<li>
				<becomeVisible>false</becomeVisible>
			</li>
		</stages>
	</HediffDef>


</Defs>