	<!-- ===============================hediff====================================================== -->
	<HediffDef>
		<defName>Heyra_Hediff_Slash</defName>
		<label>flash slash</label>

		<hediffClass>HediffWithComps</hediffClass>
		<description>attached by flash slash</description>

		<comps>
			<li Class="HediffCompProperties_Disappears">
				<disappearsAfterTicks>24</disappearsAfterTicks>
			</li>
			<li Class="Heyra.HediffCompProperties_PlayEffecter">
				<effecterDef>Heyra_Effecter_SlashTrail</effecterDef>
			</li>
		</comps>
	</HediffDef>

