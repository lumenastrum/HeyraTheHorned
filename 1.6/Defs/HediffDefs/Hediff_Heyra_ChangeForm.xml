		<addedPartProps>
			<partEfficiency>1.0</partEfficiency>
		</addedPartProps>
		<!-- [VEF FORK] Breath attack restored as MVCF hediff verb with VEF GaussProjectile -->
		<comps>
			<li Class="MVCF.Comps.HediffCompProperties_ExtendedVerbGiver">
				<verbs>
					<li>
						<label>breath attack</label>
						<verbClass>Verb_Shoot</verbClass>
						<accuracyTouch>1</accuracyTouch>
						<accuracyShort>0.9</accuracyShort>
						<accuracyMedium>0.7</accuracyMedium>
						<accuracyLong>0.6</accuracyLong>
						<hasStandardCommand>true</hasStandardCommand>
						<defaultProjectile>Heyra_Projectile_Breath</defaultProjectile>
						<warmupTime>0.6</warmupTime>
						<defaultCooldownTime>1.2</defaultCooldownTime>
						<minRange>2.8</minRange>
						<range>20</range>
						<forcedMissRadius>1.9</forcedMissRadius>
						<ticksBetweenBurstShots>12</ticksBetweenBurstShots>
						<burstShotCount>4</burstShotCount>
						<soundCast>Shot_IncendiaryLauncher</soundCast>
						<soundCastTail>GunTail_Medium</soundCastTail>
						<muzzleFlashScale>10</muzzleFlashScale>
						<targetParams>
							<canTargetLocations>true</canTargetLocations>
						</targetParams>
					</li>
				</verbs>
				<verbProps>
					<li>
						<label>breath attack</label>
					</li>
				</verbProps>
			</li>
		</comps>
	</HediffDef>
	
