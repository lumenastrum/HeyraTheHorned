  <!-- Prosthetic leg -->

  <HediffDef Name="Heyra_HediffBioHornBase" ParentName="AddedBodyPartBase" Abstract="True">
    <description>Miracle seed has exerted its power.</description>
	<label>transmogrified</label>
    <labelNoun>transmogrified horns</labelNoun>
    <addedPartProps>
      <solid>true</solid>
      <partEfficiency>1</partEfficiency>
    </addedPartProps>
	<stages>
	  <li>
            <statOffsets>
                <PsychicSensitivity>0.5</PsychicSensitivity>
            </statOffsets>
       </li>
    </stages>
  </HediffDef>
  
  <!-- [1.6 FIX] renderNodeProperties added to each biohorn HediffDef using AncotLibrary's
       PawnRenderNodeProperties_Race. This bypasses HAR's broken hediffGraphics pipeline
       and uses vanilla's DynamicPawnRenderNodeSetup_Hediffs instead. The race filter ensures
       horns only render on Heyra/Rong pawns. A companion Harmony patch in Patches_HAR
       suppresses the default HAR horn addon when any biohorn hediff is present,
       preventing double-rendering. -->

  <HediffDef ParentName="Heyra_HediffBioHornBase">
    <defName>Heyra_Biohorn0A</defName>
    <renderNodeProperties>
      <li Class="AncotLibrary.PawnRenderNodeProperties_Race">
        <texPath>Heyra/Horns/HornA</texPath>
        <parentTagDef>Head</parentTagDef>
        <shaderTypeDef>Cutout</shaderTypeDef>
        <drawData>
          <defaultData>
            <layer>56</layer>
            <offset>(0, 0.3, 0.03)</offset>
          </defaultData>
          <dataNorth>
            <offset>(0, 0, 0.03)</offset>
          </dataNorth>
        </drawData>
        <races>
          <li>Alien_Heyra</li>
          <li>Alien_Rong</li>
        </races>
      </li>
    </renderNodeProperties>
  </HediffDef>

