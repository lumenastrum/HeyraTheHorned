  <!-- VEF ExpandableProjectileDef: beam projectile with GaussProjectile rendering.
       Updated from VFECore.* to VEF.Weapons.* namespace for VEF 1.6. -->
  <VEF.Weapons.ExpandableProjectileDef ParentName="BaseBullet">
		<defName>Heyra_Bowprojectile</defName>
		<label>plasma beam</label>
		<thingClass>VEF.Weapons.GaussProjectile</thingClass>
		<graphicData>
			<texPath>Weapon/Heyra_Bowprojectile</texPath>
			<texPathFadeOut>Weapon/Heyra_Bowprojectile_Fadeout</texPathFadeOut>
		</graphicData>
		<projectile>
			<damageDef>ArrowHighVelocity</damageDef>
			<damageAmountBase>12</damageAmountBase>
			<armorPenetrationBase>2.00</armorPenetrationBase>
			<stoppingPower>1</stoppingPower>
			<speed>120</speed>
		</projectile>
		<reachMaxRangeAlways>true</reachMaxRangeAlways>
		<minDistanceToAffect>3.2</minDistanceToAffect>
		<drawOffscreen>true</drawOffscreen>
		<lifeTimeDuration>60</lifeTimeDuration>
		<widthScaleFactor>0.3</widthScaleFactor>
		<heightScaleFactor>1.6</heightScaleFactor>
		<startingPositionOffset>(0,0,3)</startingPositionOffset>
		<totalSizeScale>1.0</totalSizeScale>
		<tickFrameRate>3</tickFrameRate>
		<finalTickFrameRate>2</finalTickFrameRate>
		<tickDamageRate>5</tickDamageRate>
		<dealsDamageOnce>true</dealsDamageOnce>
		<stopWhenHit>false</stopWhenHit>
		<stopWhenHitAt>
			<li>MineableSteel</li>
			<li>CollapsedRocks</li>
			<li>MineableSilver</li>
			<li>MineableGold</li>
			<li>MineableUranium</li>
			<li>MineablePlasteel</li>
			<li>MineableJade</li>
			<li>MineableComponentsIndustrial</li>
			<li>RaisedRocks</li>
			<li>Sandstone</li>
			<li>SmoothedSandstone</li>
			<li>Granite</li>
			<li>SmoothedGranite</li>
			<li>Limestone</li>
			<li>SmoothedLimestone</li>
			<li>Slate</li>
			<li>SmoothedSlate</li>
			<li>Marble</li>
			<li>SmoothedMarble</li>
		</stopWhenHitAt>
	</VEF.Weapons.ExpandableProjectileDef>
  
  <ThingDef ParentName="BaseWeapon">
    <defName>Heyra_Celestialwhisper</defName>
    <label>Celestial Whisper</label>
    <description>A mysterious bow-like weapon that fires plasma beams capable of penetrating plasteel plates like paper, all while making almost no sound. The creator of this masterpiece remains unknown.</description>
	<techLevel>Medieval</techLevel>
    <thingCategories>
      <li>Heyra_Masterpieces</li>
    </thingCategories>
    <burnableByRecipe>false</burnableByRecipe>
    <statBases>
      <MarketValue>3000</MarketValue>
      <Mass>1.0</Mass>
	   <AccuracyTouch>0.85</AccuracyTouch>
      <AccuracyShort>1.0</AccuracyShort>
      <AccuracyMedium>1.4</AccuracyMedium>
      <AccuracyLong>1.2</AccuracyLong>
      <RangedWeapon_Cooldown>0.6</RangedWeapon_Cooldown>
    </statBases>
    <comps>
      <li>
        <compClass>CompQuality</compClass>
      </li>
      <li Class="CompProperties_Art">
        <nameMaker>NamerArtWeaponMelee</nameMaker>
        <descriptionMaker>ArtDescription_WeaponMelee</descriptionMaker>
        <minQualityForArtistic>Excellent</minQualityForArtistic>
      </li>
    </comps>
    <graphicData>
      <texPath>Weapon/Heyra_Celestialwhisper</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Bow_Large</soundInteract>
    <thingSetMakerTags>
      <li>RewardStandardMidFreq</li>
    </thingSetMakerTags>
    <weaponTags>
      <li>Heyra_RangedTypeM</li>
    </weaponTags>
    <weaponClasses>
      <li>Ranged</li>
      <li>RangedHeavy</li>
    </weaponClasses>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Heyra_Bowprojectile</defaultProjectile>
        <warmupTime>0.4</warmupTime>
        <range>26.0</range>
        <soundCast>InfernoCannon_Fire</soundCast>
		<soundCastTail>GunTail_Heavy</soundCastTail>
		<muzzleFlashScale>3</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>limb</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>
  
