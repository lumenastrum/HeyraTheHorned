	<!-- DNA Container -->	
	<ThingDef ParentName="BuildingBase">
		<defName>Heyra_Samplecontainer</defName>
		<label>mysterious container</label>
		<description>A self-powered crate that keeps the contents safly in a constant temperature and humidity chamber, making it the ideal container for long-term storage of blood samples.\n\nThis container is securely locked. The only way to acquire the contents is to deconstruct it.</description>
		<category>Building</category>
		<graphicData>
		  <texPath>Building/Heyra_Samplecontainer</texPath>
		  <graphicClass>Graphic_Multi</graphicClass>
		  <drawSize>(2,2)</drawSize>
