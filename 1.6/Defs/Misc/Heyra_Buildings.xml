<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- Tailor + Smithy -->
	<ThingDef ParentName="BenchBase">
		<defName>Heyra_Workbench</defName>
		<label>Heyran workbench</label>
		<description>A workbench for crafting Heyran items.</description>
		<thingClass>Building_WorkTable</thingClass>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToBuild>2000</WorkToBuild>
			<Flammability>1.0</Flammability>
			<WorkTableWorkSpeedFactor>1.0</WorkTableWorkSpeedFactor>
		</statBases>
		<size>(2,1)</size>
		<costList>
			<Steel>60</Steel>
			<WoodLog>40</WoodLog>
		</costList>
		<comps>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>ToolCabinet</li>
				</linkableFacilities>
			</li>
			<li Class="CompProperties_Glower">
				<glowRadius>2</glowRadius>
				<glowColor>(180,140,60,60)</glowColor>
			</li>				
		</comps>
		<graphicData>
			<texPath>Building/Heyraworkbench</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(2.6,2.6)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<castEdgeShadows>true</castEdgeShadows>
		<staticSunShadowHeight>0.20</staticSunShadowHeight>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<building>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
		</building>
		<fillPercent>0.5</fillPercent>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<hasInteractionCell>true</hasInteractionCell>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<designationCategory>Production</designationCategory>
		<surfaceType>Item</surfaceType>
		<designationHotKey>Misc12</designationHotKey>
		<constructionSkillPrerequisite>3</constructionSkillPrerequisite>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>Heyra_Researchappareltier0</li>
		</researchPrerequisites>
	</ThingDef>
	
	<ThingDef ParentName="BuildingBase">
		<defName>Heyra_Soymilkmachine</defName>
		<label>bean milk machine</label>
		<description>A machine that cooks milksoy beans into bean milk. No manual operation is required as it goes through all the processes automatically. However, your colonists still need to manually fill the ingredient tank and collect the milk produced. \n\nThis machine produces heat. Do not build this directly in your refrigerating chamber.</description>
		<thingClass>Building_WorkTable</thingClass>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<pathCost>70</pathCost>
		<rotatable>false</rotatable>
		<tickerType>Normal</tickerType>
		<statBases>
			<MaxHitPoints>300</MaxHitPoints>
			<WorkToBuild>3000</WorkToBuild>
			<Flammability>0.2</Flammability>
			<WorkTableWorkSpeedFactor>1.0</WorkTableWorkSpeedFactor>
		</statBases>
		<size>(3,2)</size>
		<costList>
			<Steel>80</Steel>
			<ComponentIndustrial>10</ComponentIndustrial>
		</costList>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>700</basePowerConsumption>
			</li>		
			<li Class="CompProperties_HeatPusher">
				<compClass>CompHeatPusherPowered</compClass>
				<heatPerSecond>4</heatPerSecond>
			  </li>
			<li Class="CompProperties_Flickable" />
			<li Class="CompProperties_Breakdownable"/>			
			<li Class="CompProperties_Refuelable">
				<fuelConsumptionRate>150</fuelConsumptionRate>
				<fuelCapacity>450.0</fuelCapacity>
				<fuelFilter>
					<thingDefs>
						<li>Heyra_Rawbean</li>
					</thingDefs>
				</fuelFilter>
				<initialFuelPercent>0</initialFuelPercent>
				<minimumFueledThreshold>0.05</minimumFueledThreshold>
				<showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
				<targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
				<initialConfigurableTargetFuelLevel>225</initialConfigurableTargetFuelLevel>
			</li>
			<li Class="Heyra.CompProperties_FuelPoweredSpawner">
				<thingToSpawn>Milk</thingToSpawn>
				<requiresFuel>true</requiresFuel>
				<requiresPower>true</requiresPower>
				<spawnCount>50</spawnCount>
				<spawnIntervalRange>60000</spawnIntervalRange>
				<writeTimeLeftToSpawn>true</writeTimeLeftToSpawn>
				<spawnMaxAdjacent>7</spawnMaxAdjacent>
				<spawnForbidden>false</spawnForbidden>
				<saveKeysPrefix>Beanmilk</saveKeysPrefix>
			</li>
			<li Class="Heyra.CompProperties_FuelPoweredSpawner">
				<thingToSpawn>Heyra_Beanpulp</thingToSpawn>
				<requiresFuel>true</requiresFuel>
				<requiresPower>true</requiresPower>
				<spawnCount>100</spawnCount>
				<spawnIntervalRange>60000</spawnIntervalRange>
				<writeTimeLeftToSpawn>true</writeTimeLeftToSpawn>
				<spawnMaxAdjacent>7</spawnMaxAdjacent>
				<spawnForbidden>false</spawnForbidden>
				<saveKeysPrefix>Beanmilk</saveKeysPrefix>
			</li>
			<!-- [1.6 FIX] OLB.CompProperties_Decorate requires Ominous Landscape Builder mod
			     which is not a listed dependency. Commented out to prevent type-not-found error. -->
			<!--
			<li Class="OLB.CompProperties_Decorate">
				<mote>
					<li>
						<label>Bean</label>
						<moteDef>Heyra_Mote_Bean</moteDef>
						<condition>
							<ifFueled>true</ifFueled>
						</condition>
						<origin>BuildingCenter</origin>
						<transformation>
							<scale>4.4~4.4</scale>
						</transformation>
						<graceTicks>80</graceTicks>
						<coexistsWithOther>true</coexistsWithOther>
					</li>
					<li>
						<label>Milk</label>
						<moteDef>Heyra_Mote_Milk</moteDef>
						<condition>
							<ifFueled>true</ifFueled>
							<ifPowered>true</ifPowered>
						</condition>
						<origin>BuildingCenter</origin>
						<transformation>
							<scale>4.4~4.4</scale>
						</transformation>
						<graceTicks>80</graceTicks>
						<coexistsWithOther>true</coexistsWithOther>
					</li>
				</mote>
			</li>
			-->
		</comps>
		<graphicData>
			<texPath>Building/Soymilkmachine</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(4.4,4.4)</drawSize>
			<drawRotated>false</drawRotated>
			<shadowData>
				<volume>(1.95,0.5,1.3)</volume>
			</shadowData>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<castEdgeShadows>true</castEdgeShadows>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<building>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
		</building>
		<fillPercent>0.5</fillPercent>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<designationCategory>Production</designationCategory>
		<surfaceType>Item</surfaceType>
		<designationHotKey>Misc12</designationHotKey>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
		<researchPrerequisites>
			<li>Heyra_Researchfarmingadvanced</li>
		</researchPrerequisites>
	</ThingDef>
	
