		<settlementNameMaker>Heyra_Namer_Settlement</settlementNameMaker>
		<melaninRange>0.7</melaninRange>
		<startingResearchTags>
			<li>Heyra_ResearchTypeStart</li>
			<li>TribalStart</li>
		</startingResearchTags>
		<apparelStuffFilter>
			<thingDefs>
				<li>Cloth</li>
				<li>Steel</li>
			</thingDefs>
		</apparelStuffFilter>
		<backstoryFilters>
			<li>
				<categories>
					<li>Outlander</li>
				</categories>
				<commonality>0.95</commonality>
			</li>
			<li>
				<categories>
					<li>Offworld</li>
				</categories>
				<commonality>0.05</commonality>
			</li>
		</backstoryFilters>
		<allowedCultures>
				<li>Heyra_Culture</li>
		</allowedCultures>		
	</FactionDef>
	
	<FactionDef ParentName="Heyra_PlayerFactionBase">
	<defName>Heyra_PlayerFactionSoldier</defName>
		<label>settlement of Heyras</label>
		<description>A settlement of Heyras.</description>
		<basicMemberKind>Heyra_ForbiddenArmyMeleeA</basicMemberKind>
	</FactionDef>
	
	<FactionDef ParentName="Heyra_PlayerFactionBase">
	<defName>Heyra_PlayerFactionGeneral</defName>
