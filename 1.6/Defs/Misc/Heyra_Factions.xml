		  <Heyra_Prophetess>1</Heyra_Prophetess>
		  <Heyra_Cook>1</Heyra_Cook>
		  <Heyra_Escort>3</Heyra_Escort>
        </options>
      </li>
      <li>
        <kindDef>Trader</kindDef>
        <traders>
          <Heyra_Trader>1</Heyra_Trader>
        </traders>
        <carriers>
          <Muffalo>2</Muffalo>
          <Dromedary>5</Dromedary>
          <Elephant>3</Elephant>
        </carriers>
        <guards>
          <Heyra_Escort>8</Heyra_Escort>
		  <Heyra_Freeman>3</Heyra_Freeman>
		  <Heyra_Ranger>4</Heyra_Ranger>
		  <Heyra_Swordmaster>3</Heyra_Swordmaster>
