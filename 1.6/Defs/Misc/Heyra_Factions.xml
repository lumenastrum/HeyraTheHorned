		<visitorTraderKinds>
			<li>Visitor_Heyra_Standard</li>
		</visitorTraderKinds>
		<baseTraderKinds>
			<li>Base_Heyra_Standard</li>
		</baseTraderKinds>
		<allowedArrivalTemperatureRange>-50~35</allowedArrivalTemperatureRange>
