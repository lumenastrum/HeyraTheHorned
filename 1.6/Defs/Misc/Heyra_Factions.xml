          <Heyra_BattleCook>5</Heyra_BattleCook>
		  <Heyra_Archer>20</Heyra_Archer>
        </options>
      </li>
	  <li>
        <kindDef>Peaceful</kindDef>
		<commonality>5</commonality>
        <options>
          <Heyra_Freeman>15</Heyra_Freeman>
          <Heyra_Artisan>5</Heyra_Artisan>
        </options>
      </li>
	  	  <li>
        <kindDef>Peaceful</kindDef>
		<commonality>5</commonality>
        <options>
          <Heyra_Freeman>5</Heyra_Freeman>
          <Heyra_Artisan>3</Heyra_Artisan>
		  <Heyra_Escort>2</Heyra_Escort>
		  <Heyra_Necromancer>1</Heyra_Necromancer>
        </options>
      </li>
	  <li>
        <kindDef>Peaceful</kindDef>
		<commonality>5</commonality>
        <options>
          <Heyra_Freeman>5</Heyra_Freeman>
          <Heyra_Aristocrat>5</Heyra_Aristocrat>
		  <Heyra_Escort>5</Heyra_Escort>
		  <Heyra_Cook>2</Heyra_Cook>
        </options>
      </li>
	  <li>
        <kindDef>Peaceful</kindDef>
		<commonality>5</commonality>
        <options>
          <Heyra_Freeman>3</Heyra_Freeman>
          <Heyra_Aristocrat>5</Heyra_Aristocrat>
		  <Heyra_Hierarch>1</Heyra_Hierarch>
