		<basicMemberKind>Heyra_Playable</basicMemberKind>
	</FactionDef>
	
	
	<!--============= NonPlayer ======================-->
	<FactionDef ParentName="FactionBase" Name="HeyraFactionBase" Abstract="True">
		<factionIconPath>Icon/Heyra_Heyraicon</factionIconPath>
		<settlementTexturePath>Icon/Heyra_Heyraicon</settlementTexturePath>
		<pawnSingular>Heyra</pawnSingular>
		<pawnsPlural>Heyras</pawnsPlural>
