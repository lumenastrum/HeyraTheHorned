				<li>Metallic</li>
				<li>Fabric</li>
				<li>Leathery</li>
				<li>Stony</li>
			</stuffCategoriesToAllow>
			<disallowedThingDefs>
				<li>Hyperweave</li>
			</disallowedThingDefs>
		</apparelStuffFilter>
		<caravanTraderKinds>
			<li>Caravan_Heyra_Merchant</li>
			<li>Caravan_Heyra_Armorer</li>
