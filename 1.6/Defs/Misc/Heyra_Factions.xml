	<FactionDef ParentName="HeyraFactionBase">
    <defName>Heyra_TradFaction</defName>
    <label>conservative Heyran faction</label>
    <description>A country consists of old-fashioned Heyras. They have been keeping their customs or beliefs for countless generations. Generally, they are less willing to cooperate with foreigners.</description>
	<factionNameMaker>Heyra_Namer_Heyratrad</factionNameMaker>
	<colorSpectrum>
      <li>(0.85, 0.75, 0.37)</li>
      <li>(0.94, 0.61, 0.06)</li>
    </colorSpectrum>
	<pawnGroupMakers>
			<!-- WalkingDead -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>10</commonality>
				<options>
					<Heyra_MobileTotem_PawnKind>10</Heyra_MobileTotem_PawnKind>					
					<Heyra_HornedSpectreUnarmed>50</Heyra_HornedSpectreUnarmed>
					<Heyra_HornedSpectreArmed>30</Heyra_HornedSpectreArmed>
					<Heyra_Necromancer>10</Heyra_Necromancer>
				</options>
			</li>
				<!-- Forbidden Army -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>25</commonality>
				<options>
					<Heyra_ForbiddenArmyMeleeA>25</Heyra_ForbiddenArmyMeleeA>
					<Heyra_ForbiddenArmyRangedA>10</Heyra_ForbiddenArmyRangedA>
				</options>
			</li>
			
			<!-- Forbidden Army + Braecher -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>25</commonality>
				<options>
					<Heyra_ForbiddenArmyMeleeA>17</Heyra_ForbiddenArmyMeleeA>
					<Heyra_ForbiddenArmyBreacher>8</Heyra_ForbiddenArmyBreacher>
					<Heyra_ForbiddenArmyRangedA>10</Heyra_ForbiddenArmyRangedA>
				</options>
			</li>
	</pawnGroupMakers>
	<!-- VEF FactionDefExtension: custom starting goodwill values.
	     Namespace updated from VFECore.FactionDefExtension to VEF.Factions.FactionDefExtension for VEF 1.6. -->
	<modExtensions>
		<li Class="VEF.Factions.FactionDefExtension">
			<startingGoodwillByFactionDefs>
				<PlayerColony>-75~-50</PlayerColony>
				<Heyra_PlayerFactionSoldier>0~50</Heyra_PlayerFactionSoldier>
				<Heyra_PlayerFactionGeneral>0~30</Heyra_PlayerFactionGeneral>
				<Heyra_RenoFaction>80~100</Heyra_RenoFaction>
			</startingGoodwillByFactionDefs>
		</li>
	</modExtensions>
  </FactionDef>
  
  <FactionDef ParentName="HeyraFactionBase">
    <defName>Heyra_RenoFaction</defName>
    <label>broad-minded Heyran faction</label>
    <description>A more progressive Heyra faction. They still keep most Heyran traditions but are open to new things. Generally, they are more friendly and easier to cooperate with.</description>
    <factionNameMaker>Heyra_Namer_Heyrareno</factionNameMaker>
	<colorSpectrum>
      <li>(0.25, 0.75, 0.47)</li>
      <li>(0.34, 0.71, 0.36)</li>
    </colorSpectrum>
	<pawnGroupMakers>
			<!-- Escorts + Rangers -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>40</commonality>
				<options>
					<Heyra_Escort>10</Heyra_Escort>	
					<Heyra_Swordmaster>5</Heyra_Swordmaster>						
					<Heyra_Ranger>20</Heyra_Ranger>
					<Heyra_BattleCook>3</Heyra_BattleCook>
				</options>
			</li>
	</pawnGroupMakers>
  </FactionDef>
  
</Defs>
