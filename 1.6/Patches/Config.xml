<?xml version="1.0" encoding="utf-8" ?>
<Patch>

<!-- VEF PatchOperationToggableSequence: opt-in toggles in mod settings.
     Namespace updated from VFECore to VEF for VEF 1.6. -->

 <Operation Class="VEF.PatchOperationToggableSequence">
    <enabled>False</enabled>
    <mods>
      <li>Heyra the Horned</li>
    </mods>
    <label>Use milksoy to fuel synthread loom (Restart Rimworld to apply)</label>
    <operations>
      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="Heyra_Loommachine"]/comps/li[4]/fuelFilter</xpath>
        <value>
          <li>
				<fuelFilter>
					<categories>
						<li>Heyra_Beancategory</li>
					</categories>
				</fuelFilter>
			</li>
        </value>
      </li>
    </operations>
  </Operation>

<Operation Class="VEF.PatchOperationToggableSequence">
    <enabled>False</enabled>
    <mods>
      <li>Heyra the Horned</li>
    </mods>
    <label>Remove all apparel restrictions in this mod (Restart Rimworld to apply)</label>
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>/Defs/AlienRace.ThingDef_AlienRace[defName = "Alien_Heyra"]/alienRace/raceRestriction/onlyUseRaceRestrictedApparel</xpath>
        <value>
          <onlyUseRaceRestrictedApparel>false</onlyUseRaceRestrictedApparel>
        </value>
      </li>
	  <li Class="PatchOperationReplace">
        <xpath>/Defs/AlienRace.ThingDef_AlienRace[defName = "Alien_Heyra_Rong"]/alienRace/raceRestriction/onlyUseRaceRestrictedApparel</xpath>
        <value>
          <onlyUseRaceRestrictedApparel>false</onlyUseRaceRestrictedApparel>
        </value>
      </li>
    </operations>
  </Operation>

</Patch>
